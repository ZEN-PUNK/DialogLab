# Text-to-Speech Configuration
TTS_PROVIDER=gemini

# LLM Configuration
LLM_PROVIDER=gemini

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Gradium TTS Fallback Configuration
GRADIUM_API_KEY=your_gradium_api_key_here
GRADIUM_TTS_ENDPOINT=https://api.gradium.ai/api/post/speech/tts
GRADIUM_TTS_MODEL=default
GRADIUM_TTS_VOICE_ID=YTpq7expH9539ERJ
# Optional per-speaker voice overrides
GRADIUM_TTS_VOICE_ID_ALICE=YTpq7expH9539ERJ
GRADIUM_TTS_VOICE_ID_BOB=LFZvm12tW_z0xfGo

# Tavily Tool Configuration
TAVILY_API_KEY=your_tavily_api_key_here
AVATAR_TAVILY_V1_ENABLED=true

# Server Configuration
NODE_ENV=development
